# =============================================================================
# LexiFlix — Environment Variables
# =============================================================================
# Copy this file to the appropriate location and fill in real values.
#   - apps/web/.env           (for the web app — loaded by Next.js)
#   - apps/nlp_service/.env   (for the NLP service — loaded by Pydantic)
#
# Required vars have no default and MUST be set. Optional vars show their
# default. See each app's documentation for details.
# =============================================================================

# ---------------------------------------------------------------------------
# Web App — Required
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@host:5432/lexiflix
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
RESEND_API_KEY=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://cdn.example.com
GOOGLE_CLOUD_API_KEY=
TRIGGER_SECRET_KEY=
NLP_SERVICE_BASE_URL=http://localhost:8000
NLP_SERVICE_API_KEY=
TMDB_API_KEY=

# ---------------------------------------------------------------------------
# Web App — Optional / Tuning (showing defaults)
# ---------------------------------------------------------------------------
NODE_ENV=development
OPENSUBTITLES_API_BASE_URL=https://api.opensubtitles.com/api/v1
OPENSUBTITLES_REQUEST_TIMEOUT_MS=20000
ANALYSIS_LLM_MODEL=gemini-3.1-flash-lite
CONTENT_GENERATION_TEXT_MODEL=gemini-3.1-flash-lite
CONTENT_GENERATION_AUDIO_PROVIDER=azure-mai
CONTENT_GENERATION_AUDIO_VOICE=lexiflix-v1
CONTENT_GENERATION_IMAGE_ENABLED=false
# CONTENT_GENERATION_IMAGE_PROVIDER= (not yet implemented, leave unset)
CONTENT_GENERATION_IMAGE_CONCURRENCY=3
AZURE_SPEECH_REGION=eastus2
AZURE_SPEECH_API_KEY=
AZURE_SPEECH_CONCURRENCY=4
AZURE_SPEECH_MAX_RETRIES=2
AZURE_MAI_VOICE_MALE=en-US-Jasper:MAI-Voice-1
AZURE_MAI_VOICE_FEMALE=en-US-June:MAI-Voice-1
AZURE_MAI_VOICE_STYLE=learning
AWS_POLLY_REGION=us-east-1
AWS_POLLY_ACCESS_KEY_ID=
AWS_POLLY_SECRET_ACCESS_KEY=
AWS_POLLY_ENGINE=standard
AWS_POLLY_STANDARD_VOICE_ID=Joanna
AWS_POLLY_NEURAL_VOICE_ID=Matthew
AWS_POLLY_CONCURRENCY=5
AWS_POLLY_MAX_RETRIES=2
NLP_SERVICE_REQUEST_TIMEOUT_MS=60000

# ---------------------------------------------------------------------------
# Web App — Public (NEXT_PUBLIC_)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development

# ---------------------------------------------------------------------------
# Web App — Trigger.dev & Internal
# ---------------------------------------------------------------------------
TRIGGER_PROJECT_REF=
TRIGGER_API_URL=https://api.trigger.dev
WS_NO_BUFFER_UTIL=1

# ===========================================================================
# NLP Service (apps/nlp_service)
# Prefix: NLP_
# ===========================================================================
NLP_APP_NAME=lexiflix-nlp-service
NLP_APP_VERSION=0.1.0
NLP_DEBUG=false
# Bearer token the web app sends as NLP_SERVICE_API_KEY. Leave unset for open local dev.
NLP_API_KEY=
NLP_HOST=0.0.0.0
NLP_PORT=8000
NLP_LOG_LEVEL=info
NLP_SPACY_BATCH_SIZE=125
NLP_DEFAULT_INCLUDE_PROPN=false
NLP_DEFAULT_DEDUP_LINES=true

# ===========================================================================
# NLP Service — Docker / Build
# ===========================================================================
SPACY_MODEL=en_core_web_trf
UV_VERSION=0.8.13
UV_HTTP_TIMEOUT=120
UV_LINK_MODE=copy
UV_COMPILE_BYTECODE=1
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
VIRTUAL_ENV=/app/.venv

# ===========================================================================
# Scripts (apps/scripts)
# ===========================================================================
GOOGLE_CLOUD_API_KEY=

# ===========================================================================
# Taskfile / Infra
# ===========================================================================
DOPPLER_PROJECT=lexiflix_web
DOPPLER_CONFIG=dev
IMAGE_NAME=lexiflix-nlp-service
PORT=8000

# ===========================================================================
# CI/CD — GitHub Actions (nlp-service-deploy)
# ===========================================================================
AZURE_RESOURCE_GROUP=lexiflix-rg
AZURE_CONTAINER_APP_ENV=lexiflix-aca-env
AZURE_APP_NAME=lexiflix-nlp
